# --- YouTube Data API v3 ---
# Create a key at https://console.cloud.google.com/apis/credentials after enabling
# "YouTube Data API v3" on the project. Restrict the key to that API.
YOUTUBE_API_KEY=

# The channel to pull classes from. Easiest way to get this: go to the channel's
# page, view page source, and search for "channelId", or use
# https://www.youtube.com/@handle -> "About" -> "Share channel" -> copy link,
# which resolves to a UC... id. Must start with "UC".
YOUTUBE_CHANNEL_ID=

# --- SoundCloud ---
# SoundCloud closed public API registration years ago, so this app talks to the
# same public, unauthenticated endpoint (api-v2.soundcloud.com) that
# soundcloud.com itself uses in the browser for anonymous/public data. To get a
# client_id: open soundcloud.com in a browser, open DevTools -> Network, reload,
# and copy the "client_id" query param from any request to api-v2.soundcloud.com.
# It's a public, non-secret id (not a login credential) and only grants access to
# publicly visible tracks/playlists. It can occasionally rotate; see
# backend/README section "SoundCloud client_id" for how to refresh it.
SOUNDCLOUD_CLIENT_ID=

# The account (permalink) to pull classes from, e.g. for
# soundcloud.com/torah-center-atlanta this is "torah-center-atlanta".
SOUNDCLOUD_USERNAME=

# --- Caching / refresh ---
# How often (seconds) to re-pull YouTube/SoundCloud in the background.
# 3600 = hourly, matches the product spec.
REFRESH_INTERVAL_SECONDS=3600

# Comma-separated list of origins allowed to call this API (your frontend URL).
# Use * only for local development.
CORS_ORIGINS=http://localhost:5173
